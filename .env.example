POLYGON_API_KEY=your_polygon_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here
TELEGRAM_SUBSCRIBER_CHAT_IDS=admin_chat_id,friend_chat_id_1,friend_chat_id_2

# Optional: restrict each subscriber's daily report to specific tickers.
# Format: chat_id1:TICKER1,TICKER2,...;chat_id2:TICKER3,...
# Subscribers NOT listed here receive the full report (all tickers).
# Subscribers /can still use /detail TICKER for any ticker regardless of this filter.
# Example: friend_chat_id_1 only sees AAPL and MSFT; friend_chat_id_2 sees NVDA and AMD.
# TELEGRAM_SUBSCRIBER_TICKERS=friend_chat_id_1:AAPL,MSFT;friend_chat_id_2:NVDA,AMD
